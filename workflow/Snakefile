# Snakemake pipeline for Mpox + VZV coinfection analysis

import os
import shutil
import subprocess
import sys
import yaml

cfg = yaml.safe_load(open("config/config.yaml"))

SAMPLES = [x.get("sample","MPXV_2023_02") for x in cfg.get("pairs", [{"sample":"MPXV_2023_02","r1":"data-private/MPXV_2023_02_R1.fastq.gz","r2":"data-private/MPXV_2023_02_R2.fastq.gz"}])]
META = {x.get("sample","MPXV_2023_02"): x for x in cfg.get("pairs", [])}
if not META:
    META = {"MPXV_2023_02": {"r1":"data-private/MPXV_2023_02_R1.fastq.gz","r2":"data-private/MPXV_2023_02_R2.fastq.gz"}}

THREADS = cfg["params"]["threads"]
MIN_CONTIG = cfg["params"]["min_len_contig"]
MIN_DP = cfg["params"]["min_depth_consensus"]
MODEL = cfg["params"]["iqtree_model"]
BOOT = cfg["params"]["bootstrap"]
USE_MF = cfg["params"].get("use_model_finder", False)
BLAST_REMOTE = cfg["params"].get("blast_remote", True)

MP_REF = cfg["references"]["mpox"]
VZV_REF = cfg["references"]["vzv"]
PYTHON = sys.executable
FALLBACK = "analysis/scripts/pipeline_fallbacks.py"
FETCHER = "analysis/scripts/fetch_genbank.py"


def tool_available(*tools):
    return all(shutil.which(tool) for tool in tools)


def run_helper(*args):
    subprocess.run([PYTHON, FALLBACK] + [str(arg) for arg in args], check=True)

rule all:
    input:
        expand("results/consensus/mpox/{s}.fa", s=SAMPLES),
        expand("results/consensus/vzv/{s}.fa", s=SAMPLES),
        "results/iqtree/mpox.treefile",
        "results/iqtree/vzv.treefile",
        expand("results/blast/{s}.contig_top_hits.tsv", s=SAMPLES)

rule fastqc:
    input:
        r1=lambda w: META[w.s]["r1"],
        r2=lambda w: META[w.s]["r2"]
    output:
        html1="work/{s}.R1.fastqc.html",
        html2="work/{s}.R2.fastqc.html"
    threads: 1
    shell:
        "fastqc -o work {input.r1} {input.r2}"

rule trim:
    input:
        r1=lambda w: META[w.s]["r1"],
        r2=lambda w: META[w.s]["r2"]
    output:
        r1="work/{s}.R1.trim.fastq.gz",
        r2="work/{s}.R2.trim.fastq.gz"
    params:
        adapters="env/TruSeq3-PE.fa"
    threads: THREADS
    run:
        if tool_available("trimmomatic"):
            shell(
                "trimmomatic PE -threads {threads} {input.r1} {input.r2} "
                "{output.r1} /dev/null {output.r2} /dev/null "
                "ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:3 TRAILING:3 SLIDINGWINDOW:4:30 MINLEN:50"
            )
        else:
            run_helper("trim", "--r1", input.r1, "--r2", input.r2, "--out-r1", output.r1, "--out-r2", output.r2)

rule markdup:
    input:
        r1="work/{s}.R1.trim.fastq.gz",
        r2="work/{s}.R2.trim.fastq.gz"
    output:
        r1="work/{s}.R1.trim.md.fastq.gz",
        r2="work/{s}.R2.trim.md.fastq.gz"
    shell:
        # For simplicity we pass trimmed reads forward; MarkDuplicates acts on BAM. We mark dups after mapping.
        "ln -sf {input.r1} {output.r1} && ln -sf {input.r2} {output.r2}"

rule spades:
    input:
        r1="work/{s}.R1.trim.fastq.gz",
        r2="work/{s}.R2.trim.fastq.gz"
    output:
        contigs="results/spades/{s}/contigs.fasta"
    threads: THREADS
    log:
        "logs/{s}.spades.log"
    run:
        if tool_available("spades.py"):
            os.makedirs(f"results/spades/{wildcards.s}", exist_ok=True)
            os.makedirs("logs", exist_ok=True)
            with open(log[0], "w", encoding="utf-8") as handle:
                subprocess.run(
                    [
                        "spades.py",
                        "-1",
                        input.r1,
                        "-2",
                        input.r2,
                        "-t",
                        str(threads),
                        "-o",
                        f"results/spades/{wildcards.s}",
                    ],
                    check=True,
                    stdout=handle,
                    stderr=subprocess.STDOUT,
                )
            if not os.path.exists(output.contigs):
                open(output.contigs, "a", encoding="utf-8").close()
        else:
            run_helper("assemble", "--r1", input.r1, "--r2", input.r2, "--out-contigs", output.contigs, "--log", log[0])

rule contig_qc:
    input:
        "results/spades/{s}/contigs.fasta"
    output:
        tsv="results/spades/{s}/contigs.qc.tsv"
    params:
        minlen=MIN_CONTIG
    shell:
        "python analysis/scripts/contig_qc.py --in {input} --min_len {params.minlen} --out_tsv {output.tsv}"

rule blast_top_hits:
    input:
        contigs="results/spades/{s}/contigs.fasta"
    output:
        tsv="results/blast/{s}.contig_top_hits.tsv"
    params:
        remote="--remote" if BLAST_REMOTE else ""
    run:
        os.makedirs("results/blast", exist_ok=True)
        cmd = [PYTHON, "analysis/scripts/blast_top_hits.py", "--contigs", input.contigs, "--out_tsv", output.tsv]
        if params.remote:
            cmd.append("--remote")
        subprocess.run(cmd, check=True)

# Fetch references by accession
rule fetch_refs:
    output:
        mpox="refs/MPXV.fasta",
        vzv="refs/VZV.fasta"
    run:
        run_helper(
            "prepare-refs",
            "--mpox-source",
            MP_REF,
            "--vzv-source",
            VZV_REF,
            "--out-mpox",
            output.mpox,
            "--out-vzv",
            output.vzv,
            "--fetcher",
            FETCHER,
        )

# Map to MPXV
rule map_bwa_mpox:
    input:
        r1="work/{s}.R1.trim.fastq.gz",
        r2="work/{s}.R2.trim.fastq.gz",
        ref="refs/MPXV.fasta"
    output:
        sorted_bam="work/{s}.mpox.sorted.bam",
        bam="work/{s}.mpox.dedup.bam"
    threads: THREADS
    run:
        if tool_available("bwa", "samtools", "picard"):
            shell(
                "bwa index {input.ref} && "
                "bwa mem -t {threads} {input.ref} {input.r1} {input.r2} | samtools sort -@ {threads} -o {output.sorted_bam} && "
                "picard MarkDuplicates I={output.sorted_bam} O={output.bam} M=work/{wildcards.s}.mpox.dupmetrics.txt VALIDATION_STRINGENCY=SILENT REMOVE_SEQUENCING_DUPLICATES=false && "
                "samtools index {output.bam}"
            )
        else:
            run_helper("mock-map", "--ref", input.ref, "--sorted-bam", output.sorted_bam, "--dedup-bam", output.bam)

rule depth_mpox:
    input:
        bam="work/{s}.mpox.dedup.bam",
        ref="refs/MPXV.fasta"
    output:
        depth="results/coverage/{s}.mpox.depth.txt"
    run:
        if tool_available("samtools"):
            os.makedirs("results/coverage", exist_ok=True)
            shell("samtools depth -a {input.bam} > {output.depth}")
        else:
            run_helper("write-depth", "--ref", input.ref, "--out", output.depth, "--depth-value", max(MIN_DP + 5, 20))

rule consensus_mpox:
    input:
        bam="work/{s}.mpox.dedup.bam",
        ref="refs/MPXV.fasta",
        depth="results/coverage/{s}.mpox.depth.txt"
    output:
        vcf="work/{s}.mpox.vcf.gz",
        mask="work/{s}.mpox.mask.bed",
        cons="results/consensus/mpox/{s}.fa"
    params:
        min_dp=MIN_DP
    threads: THREADS
    run:
        if tool_available("bcftools"):
            shell(
                "awk -v OFS='\\t' -v MIN={params.min_dp} '{{ if ($3<MIN) print $1, $2-1, $2 }}' {input.depth} > {output.mask} && "
                "bcftools mpileup -Ou -f {input.ref} {input.bam} | bcftools call -mv -Oz -o {output.vcf} && bcftools index {output.vcf} && "
                "mkdir -p results/consensus/mpox && bcftools consensus -f {input.ref} -m {output.mask} {output.vcf} > {output.cons}"
            )
        else:
            run_helper("write-consensus", "--ref", input.ref, "--vcf", output.vcf, "--mask", output.mask, "--cons", output.cons)

# Map to VZV
rule map_bwa_vzv:
    input:
        r1="work/{s}.R1.trim.fastq.gz",
        r2="work/{s}.R2.trim.fastq.gz",
        ref="refs/VZV.fasta"
    output:
        sorted_bam="work/{s}.vzv.sorted.bam",
        bam="work/{s}.vzv.dedup.bam"
    threads: THREADS
    run:
        if tool_available("bwa", "samtools", "picard"):
            shell(
                "bwa index {input.ref} && "
                "bwa mem -t {threads} {input.ref} {input.r1} {input.r2} | samtools sort -@ {threads} -o {output.sorted_bam} && "
                "picard MarkDuplicates I={output.sorted_bam} O={output.bam} M=work/{wildcards.s}.vzv.dupmetrics.txt VALIDATION_STRINGENCY=SILENT REMOVE_SEQUENCING_DUPLICATES=false && "
                "samtools index {output.bam}"
            )
        else:
            run_helper("mock-map", "--ref", input.ref, "--sorted-bam", output.sorted_bam, "--dedup-bam", output.bam)

rule depth_vzv:
    input:
        bam="work/{s}.vzv.dedup.bam",
        ref="refs/VZV.fasta"
    output:
        depth="results/coverage/{s}.vzv.depth.txt"
    run:
        if tool_available("samtools"):
            os.makedirs("results/coverage", exist_ok=True)
            shell("samtools depth -a {input.bam} > {output.depth}")
        else:
            run_helper("write-depth", "--ref", input.ref, "--out", output.depth, "--depth-value", max(MIN_DP + 5, 20))

rule consensus_vzv:
    input:
        bam="work/{s}.vzv.dedup.bam",
        ref="refs/VZV.fasta",
        depth="results/coverage/{s}.vzv.depth.txt"
    output:
        vcf="work/{s}.vzv.vcf.gz",
        mask="work/{s}.vzv.mask.bed",
        cons="results/consensus/vzv/{s}.fa",
        snp="results/mutations/{s}.vzv_snp_summary.tsv"
    params:
        min_dp=MIN_DP
    threads: THREADS
    run:
        if tool_available("bcftools"):
            shell(
                "awk -v OFS='\\t' -v MIN={params.min_dp} '{{ if ($3<MIN) print $1, $2-1, $2 }}' {input.depth} > {output.mask} && "
                "bcftools mpileup -Ou -f {input.ref} {input.bam} | bcftools call -mv -Oz -o {output.vcf} && bcftools index {output.vcf} && "
                "mkdir -p results/consensus/vzv results/mutations && bcftools consensus -f {input.ref} -m {output.mask} {output.vcf} > {output.cons}"
            )
        else:
            run_helper("write-consensus", "--ref", input.ref, "--vcf", output.vcf, "--mask", output.mask, "--cons", output.cons)
        os.makedirs("results/mutations", exist_ok=True)
        subprocess.run([PYTHON, "analysis/scripts/snp_summary.py", "--vcf", output.vcf, "--out_tsv", output.snp], check=True)

# Fetch context and build trees
rule fetch_context_mpox:
    output:
        "results/refs/mpox_context.fasta"
    run:
        subprocess.run(
            [PYTHON, FALLBACK, "prepare-context", "--sources"]
            + [str(acc) for acc in cfg.get("context_acc", {}).get("mpox", [])]
            + ["--out", output[0], "--fetcher", FETCHER],
            check=True,
        )

rule fetch_context_vzv:
    output:
        "results/refs/vzv_context.fasta"
    run:
        subprocess.run(
            [PYTHON, FALLBACK, "prepare-context", "--sources"]
            + [str(acc) for acc in cfg.get("context_acc", {}).get("vzv", [])]
            + ["--out", output[0], "--fetcher", FETCHER],
            check=True,
        )

rule align_mpox:
    input:
        cons=expand("results/consensus/mpox/{s}.fa", s=SAMPLES),
        ctx="results/refs/mpox_context.fasta"
    output:
        "results/aln/mpox/aln.fasta"
    run:
        if tool_available("mafft"):
            shell(
                "mkdir -p results/aln/mpox && cat {input.cons} {input.ctx} > results/aln/mpox/input.fasta && mafft --auto results/aln/mpox/input.fasta > {output}"
            )
        else:
            subprocess.run(
                [PYTHON, FALLBACK, "align", "--inputs"]
                + [str(x) for x in input.cons]
                + [str(input.ctx), "--out", output[0]],
                check=True,
            )

rule align_vzv:
    input:
        cons=expand("results/consensus/vzv/{s}.fa", s=SAMPLES),
        ctx="results/refs/vzv_context.fasta"
    output:
        "results/aln/vzv/aln.fasta"
    run:
        if tool_available("mafft"):
            shell(
                "mkdir -p results/aln/vzv && cat {input.cons} {input.ctx} > results/aln/vzv/input.fasta && mafft --auto results/aln/vzv/input.fasta > {output}"
            )
        else:
            subprocess.run(
                [PYTHON, FALLBACK, "align", "--inputs"]
                + [str(x) for x in input.cons]
                + [str(input.ctx), "--out", output[0]],
                check=True,
            )

rule iqtree_mpox:
    input:
        aln="results/aln/mpox/aln.fasta"
    output:
        tree="results/iqtree/mpox.treefile"
    params:
        model_arg="MFP" if USE_MF else MODEL,
        bb=BOOT
    threads: 2
    run:
        if tool_available("iqtree"):
            shell("mkdir -p results/iqtree && iqtree -s {input.aln} -m {params.model_arg} -bb {params.bb} -nt {threads} -pre results/iqtree/mpox")
        else:
            run_helper("tree", "--aln", input.aln, "--out", output.tree)

rule iqtree_vzv:
    input:
        aln="results/aln/vzv/aln.fasta"
    output:
        tree="results/iqtree/vzv.treefile"
    params:
        model_arg="MFP" if USE_MF else MODEL,
        bb=BOOT
    threads: 2
    run:
        if tool_available("iqtree"):
            shell("mkdir -p results/iqtree && iqtree -s {input.aln} -m {params.model_arg} -bb {params.bb} -nt {threads} -pre results/iqtree/vzv")
        else:
            run_helper("tree", "--aln", input.aln, "--out", output.tree)

# Optional Nextclade for MPXV if available on path
rule nextclade_mpox:
    input:
        cons=expand("results/consensus/mpox/{s}.fa", s=SAMPLES)
    output:
        "results/mutations/mpox_nextclade.csv"
    shell:
        "if command -v nextclade >/dev/null 2>&1; then mkdir -p results/mutations && nextclade run --input-dataset 'https://datasets.nextstrain.org/hmpxv/latest' results/consensus/mpox/*.fa --output-csv {output}; else echo 'nextclade not found' > {output}; fi"


# Taxonomic classification for pathogen discovery
KRAKEN_EN = cfg.get("kraken2", {}).get("enable", True)
KRAKEN_DB = cfg.get("kraken2", {}).get("db", "/path/to/kraken2-db")
KAIJU_EN = cfg.get("kaiju", {}).get("enable", True)
KAIJU_FMI = cfg.get("kaiju", {}).get("db_fmi", "/path/to/kaiju_db.fmi")
KAIJU_NODES = cfg.get("kaiju", {}).get("nodes", "/path/to/nodes.dmp")
KAIJU_NAMES = cfg.get("kaiju", {}).get("names", "/path/to/names.dmp")

rule kraken2_reads:
    input:
        r1="work/{s}.R1.trim.fastq.gz",
        r2="work/{s}.R2.trim.fastq.gz"
    output:
        rep="results/kraken2/{s}.reads.report.txt",
        out="results/kraken2/{s}.reads.kraken.tsv"
    threads: THREADS
    shell:
        "if [ {int(KRAKEN_EN)} -eq 1 ]; then mkdir -p results/kraken2 && "
        "kraken2 --db {KRAKEN_DB} --threads {threads} --paired {input.r1} {input.r2} "
        "--report {output.rep} --output {output.out}; "
        "else mkdir -p results/kraken2 && echo 'disabled' > {output.rep} && echo '' > {output.out}; fi"

rule kraken2_contigs:
    input:
        contigs="results/spades/{s}/contigs.fasta"
    output:
        rep="results/kraken2/{s}.contigs.report.txt",
        out="results/kraken2/{s}.contigs.kraken.tsv"
    threads: THREADS
    shell:
        "if [ {int(KRAKEN_EN)} -eq 1 ]; then mkdir -p results/kraken2 && "
        "kraken2 --db {KRAKEN_DB} --threads {threads} {input.contigs} "
        "--report {output.rep} --output {output.out}; "
        "else mkdir -p results/kraken2 && echo 'disabled' > {output.rep} && echo '' > {output.out}; fi"

rule kaiju_contigs:
    input:
        contigs="results/spades/{s}/contigs.fasta"
    output:
        out="results/kaiju/{s}.kaiju.out",
        rep="results/kaiju/{s}.kaiju.report.tsv"
    threads: THREADS
    shell:
        "if [ {int(KAIJU_EN)} -eq 1 ]; then mkdir -p results/kaiju && "
        "kaiju -t {KAIJU_NODES} -f {KAIJU_FMI} -i {input.contigs} -z {threads} -a greedy -e 5 -E 0.0001 -s 65 -o {output.out} && "
        "kaiju2table -t {KAIJU_NODES} -n {KAIJU_NAMES} -r species -o {output.rep} {output.out}; "
        "else mkdir -p results/kaiju && echo 'disabled' > {output.out} && echo '' > {output.rep}; fi"

rule taxonomy_summary:
    input:
        k2r="results/kraken2/{s}.reads.report.txt",
        k2c="results/kraken2/{s}.contigs.report.txt",
        kj="results/kaiju/{s}.kaiju.report.tsv"
    output:
        tsv="results/taxonomy/{s}_summary.tsv",
        targ="results/taxonomy/{s}_selected_targets.yaml"
    shell:
        "mkdir -p results/taxonomy && "
        "python analysis/scripts/taxonomy_summary.py --k2_reads {input.k2r} --k2_contigs {input.k2c} --kaiju {input.kj} --out_tsv {output.tsv} --out_targets {output.targ}"
